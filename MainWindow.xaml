<Window x:Class="SleepOnLan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        Title="SleepOnLan 控制面板" Height="480" Width="650" 
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F5F5F5" Icon="/AppIcon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="SleepOnLan" FontSize="24" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text=" 远程控制服务" FontSize="14" VerticalAlignment="Bottom" Margin="5,0,0,4" Foreground="#666"/>
        </StackPanel>

        <!-- 控制区域 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="监听端口" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#555"/>
                    <TextBox x:Name="TxtPort" Text="9999" Width="70" VerticalAlignment="Center" Padding="8,5" 
                             VerticalContentAlignment="Center" BorderBrush="#DDD" BorderThickness="1"/>
                </StackPanel>

                <Button x:Name="BtnSwitch" Grid.Column="1" Content="启动服务器" Click="BtnSwitch_Click" 
                        Margin="20,0,0,0" Width="110" Height="36" Cursor="Hand"
                        Background="#4CAF50" Foreground="White" BorderThickness="0" FontWeight="Medium">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45a049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 状态指示器 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="#9E9E9E" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatus" Text="未运行" VerticalAlignment="Center" Foreground="#666"/>
                </StackPanel>

                <CheckBox x:Name="ChkAutoStart" Grid.Column="4" Content="开机自启" 
                          VerticalAlignment="Center" Click="ChkAutoStart_Click" Foreground="#555"/>
            </Grid>
        </Border>

        <!-- 日志区域 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" Background="#FAFAFA" CornerRadius="8,8,0,0" Padding="15,10">
                    <TextBlock Text="活动日志" FontWeight="Medium" Foreground="#333"/>
                </Border>
                
                <TextBox x:Name="TxtLog" Grid.Row="1" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" 
                         Background="Transparent" FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Padding="15" Foreground="#444"/>
            </Grid>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="设置" Click="BtnSettings_Click" Width="70" Height="32" Margin="0,0,10,0"
                    Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="清除日志" Click="BtnClearLog_Click" Width="80" Height="32" Margin="0,0,10,0"
                    Background="#E0E0E0" Foreground="#333" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D5D5D5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="退出程序" Click="MenuExit_Click" Width="80" Height="32"
                    Background="#f44336" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da190b"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <tb:TaskbarIcon x:Name="MyNotifyIcon" 
                        IconSource="/AppIcon.ico" 
                        ToolTipText="SleepOnLan 运行中">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="MenuShow_Click"/>
                    <Separator/>
                    <MenuItem Header="退出程序" Click="MenuExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
